# ── Backend .env ─────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

# SQLite DB path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./medidecide.db

# CORS — set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:3000
